// Prisma schema for Gastronomie Web-App
// SQLite for local dev (switch to postgresql for production)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User: role values: "CUSTOMER" | "ADMIN" | "RESTAURANT_MANAGER"
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("CUSTOMER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders       Order[]
  addresses    Address[]
  redemptions  CouponRedemption[]
  reservations Reservation[]
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String
  image       String?
  active      Boolean  @default(true)
  // comma-separated short allergen codes, e.g. "Gluten,Laktose,Nüsse"
  allergens   String?
  // freeform ingredient description
  ingredients String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

// Coupon: discountType values: "PERCENT" | "FIXED"
model Coupon {
  id             String   @id @default(cuid())
  code           String   @unique
  title          String
  subtitle       String
  imageUrl       String?
  discountText   String
  discountType   String
  discountValue  Float
  minOrderValue  Float?
  validUntil     DateTime
  usageLimit     Int?
  usedCount      Int      @default(0)
  isPersonalized Boolean  @default(true)
  createdAt      DateTime @default(now())

  redemptions    CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  userId     String
  couponId   String
  redeemedAt DateTime @default(now())
  orderId    String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@unique([userId, couponId])
}

// Reservation: status values: "PENDING" | "CONFIRMED" | "CANCELLED"
model Reservation {
  id         String   @id @default(cuid())
  userId     String?
  guestName  String
  guestEmail String
  guestPhone String
  date       DateTime
  partySize  Int
  notes      String?
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Order: orderType values: "PICKUP" | "DELIVERY"
// Order: status values: "PENDING" | "CONFIRMED" | "PREPARING" | "READY" | "COMPLETED" | "CANCELLED"
model Order {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderType   String   @default("PICKUP")
  status      String   @default("CONFIRMED")
  totalAmount Float
  tipAmount   Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items     OrderItem[]
  addresses Address[]
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  price         Float
  couponApplied String?

  @@unique([orderId, productId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId    String?
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  street     String
  city       String
  postalCode String
  country    String
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
}
